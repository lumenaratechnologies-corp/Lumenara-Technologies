# Add project env vars here. Restart dev server after changes.
# Google Sign-In (frontend only uses Client ID; never put Client Secret in frontend)
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Gemini API Key for client-side chat model integrations
# VITE_GEMINI_API_KEY=your-gemini-api-key-here

